<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Стяжка Pro</title>
  
  <!-- Подключаем стили -->
  <link rel="stylesheet" href="css/styles.css">
  
  <!-- Библиотеки -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@capacitor/core@6/dist/capacitor.js"></script>
</head>
<body>
  <div class="header"><h2>📐 Стяжка Pro</h2></div>

  <!-- Страница замеров -->
  <div class="page active" id="pMeas">
    <div class="card">
      <label>📍 Адрес</label><input id="addr" placeholder="Улица, дом">
      <label>👤 Заказчик</label><input id="client" placeholder="Иванов И.И.">
      <label>📅 Дата</label><input type="date" id="date">
    </div>
    <div id="rooms"></div>
    <button class="btn btn-p" onclick="addRoom()">+ Комната</button>
    <div class="card">
      <div>Площадь: <b id="tArea">0 м²</b></div>
      <div>Слой: <b id="tLayer">0 см</b></div>
      <div>Объём: <b id="tVol">0 м³</b></div>
    </div>
    <button class="btn btn-p" onclick="saveMeas()">💾 Сохранить замер</button>
    <button class="btn btn-s" onclick="openPDFModal('measure')">📄 Лист замера</button>
  </div>

  <!-- Страница стоимости -->
  <div class="page" id="pCost">
    <div class="card"><h3>💰 Расчёт стоимости</h3><p>Выберите замер из истории для расчёта.</p></div>
  </div>

  <!-- Страница истории -->
  <div class="page" id="pHist">
    <div class="card"><h3>📁 Архив</h3><ul id="list" style="list-style:none"></ul></div>
  </div>

  <!-- Страница настроек -->
  <div class="page" id="pSet">
    <div class="card"><h3>⚙️ Настройки</h3><p>Здесь будут цены и параметры.</p></div>
  </div>

  <!-- Модальное окно PDF -->
  <div class="modal" id="pdfModal">
    <div class="modal-box">
      <h3 id="mTitle">Документ</h3>
      <p id="mText">Готово к сохранению</p>
      <button class="btn btn-s" onclick="startPDF()">📥 Сохранить в Screed1</button>
      <button class="btn" onclick="closeModal()">Отмена</button>
    </div>
  </div>

  <!-- Навигация -->
  <nav class="nav">
    <button class="act" onclick="go('pMeas',this)">📐 Замеры</button>
    <button onclick="go('pCost',this)">💰 Стоимость</button>
    <button onclick="go('pHist',this)">📁 История</button>
    <button onclick="go('pSet',this)">⚙️ Настройки</button>
  </nav>
  
  <div class="toast" id="toast"></div>

  <!-- Подключаем JS файлы (порядок важен!) -->
  <script src="js/config.js"></script>
  <script src="js/fileService.js"></script>
  <script src="js/app.js"></script>
</body>
</html>
